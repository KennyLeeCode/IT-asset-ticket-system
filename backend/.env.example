# Copy this file to .env and fill in your actual values

# The address where your MySQL database is running
DB_HOST=localhost

# Your MySQL username
DB_USER=root

# Your MySQL password
DB_PASSWORD=yourpassword

# The name of the database we will create and use
DB_NAME=it_asset_system

# Secret key used to sign and verify login tokens (make this long and random)
JWT_SECRET=your_super_secret_jwt_key_change_this

# The port the backend server will listen on
PORT=5000
